{
  "project_name": "Online Examination and Proctoring System (OEPS)",
  "project_summary": "A comprehensive, production-ready online examination platform with built-in proctoring capabilities. Features RBAC (Admin, Examiner, Student), exam creation with MCQ/Subjective questions, timed exam attempts with auto-save, browser-based proctoring (tab switch/blur detection), automatic MCQ grading, manual subjective evaluation, and exam reporting. Built with FastAPI (async Python) backend, PostgreSQL database, and a Vite-compiled TypeScript + vanilla CSS frontend served via Nginx. Orchestrated with Docker Compose.",
  "version": 1,
  "change_in_progress": false,
  "last_updated_for_change": "initial-mapping",
  "generated_at": "2026-04-23T03:03:00+05:30",
  "architecture": {
    "pattern": "Layered Architecture (Presentation → API → Service → Repository → Database)",
    "platform": "Web (Docker Compose: PostgreSQL + FastAPI + Nginx)",
    "storage": "PostgreSQL 15 via SQLAlchemy 2.0 (Async) + Alembic migrations",
    "state_management": "Server-side session via JWT tokens; client-side localStorage for token persistence",
    "notes": "Services and repositories directories exist but are empty — all business logic currently lives directly in API route handlers. Frontend uses multi-page architecture (4 HTML pages) with per-page TypeScript modules bundled by Vite."
  },
